{
  "compilerOptions": {
    "checkJs": true,
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react",
    "target": "es2020",
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./", // 이 경로를 기준으로 모듈을 검색
    "paths": {
      // 절대 경로 별칭을 사용하는 경우 추가
      "@components/*": ["src/components/*"]
    }
  },
  "include": ["src/**/*"], // src 폴더 전체를 검색 대상으로 지정
  "exclude": ["node_modules"]
}
